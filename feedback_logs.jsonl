import csv
from pathlib import Path
import json

BASE_DIR = Path(__file__).resolve().parent
LOG_FILE = BASE_DIR / "feedback_logs.jsonl"
EXPORT_FILE = BASE_DIR / "report.csv"


class FeedbackStore:

    def export_csv(self):
        if not LOG_FILE.exists():
            return None

        with open(LOG_FILE, "r", encoding="utf-8") as f, \
             open(EXPORT_FILE, "w", newline="", encoding="utf-8") as out:

            writer = csv.writer(out)
            writer.writerow(["timestamp", "question", "answer", "sources", "feedback"])

            for line in f:
                data = json.loads(line)
                writer.writerow([
                    data["timestamp"],
                    data["question"],
                    data["answer"],
                    "|".join(data["sources"]),
                    data["feedback"]
                ])

        return EXPORT_FILE{"timestamp": "2026-06-22T11:50:59.422008", "question": "what is working hours?", "answer": "According to the Employee Handbook, standard office hours are Monday through Friday, 9:00 AM to 5:00 PM. Employees must notify their supervisor if they expect to arrive late or be absent.", "sources": ["employee_handbook.txt", "remote_work_policy.txt"], "feedback": "y"}
